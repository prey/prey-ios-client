# Copy this file to .apns.env and fill in your values
# TEAM_ID and KEY_ID come from Apple Developer → Keys
# P8_KEY_PATH points to AuthKey_<KEY_ID>.p8 on your machine

TEAM_ID=YOUR_TEAM_ID
KEY_ID=YOUR_KEY_ID
P8_KEY_PATH=/absolute/path/to/AuthKey_YOUR_KEY_ID.p8

# Bundle ID of the main app (not the extension)
BUNDLE_ID=com.prey

# Device token printed by your app after registration
DEVICE_TOKEN=YOUR_DEVICE_TOKEN

# Optional overrides (defaults shown)
APNS_ENV=sandbox         # or prod
APNS_PUSH_TYPE=location  # or background
APNS_PRIORITY=high       # or normal

